{
  "name": "ai-craft",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint && eslint packages tests *.config.* --max-warnings=0",
    "lint:staged": "lint-staged",
    "typecheck": "turbo run typecheck",
    "typecheck:references": "tsc -b tsconfig.json --pretty false",
    "clean": "rm -rf apps/web/.next output test-results",
    "prepare": "husky",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:workspace": "playwright test tests/workspace-smoke.spec.mjs",
    "test:live": "playwright test tests/live-smoke.spec.mjs",
    "test:renderer": "playwright test tests/renderer-regression.spec.mjs",
    "test:renderer:update": "AI_CRAFT_UPDATE_RENDERER_BASELINES=1 playwright test tests/renderer-regression.spec.mjs",
    "audit:ui-library": "node scripts/ui-library-audit.mjs",
    "test:ci": "npm run lint && npm run typecheck && npm run typecheck:references && npm run test:unit && npm run test:renderer && npm run test:workspace && npm run build",
    "generate:sds-tokens": "node scripts/generate-sds-theme.mjs",
    "generate:openapi": "openapi-typescript serverless/workspace-api/gateway.openapi.yaml -o packages/workspace-sdk/src/generated/workspace-api.ts && openapi-typescript serverless/media-api/gateway.openapi.yaml -o packages/workspace-sdk/src/generated/media-api.ts",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "figma:web:connect": "npm --workspace @ai-craft/web run figma:connect",
    "figma:web:publish": "npm --workspace @ai-craft/web run figma:publish",
    "figma:web:unpublish": "npm --workspace @ai-craft/web run figma:unpublish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.54.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.54.0",
    "turbo": "^2.8.19",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
