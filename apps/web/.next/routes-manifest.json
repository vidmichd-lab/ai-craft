{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/assets/[...path]",
      "regex": "^/assets/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/assets/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/fav/[...path]",
      "regex": "^/fav/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/fav/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/font/[...path]",
      "regex": "^/font/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/font/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/legacy-app/[[...path]]",
      "regex": "^/legacy\\-app(?:/(.+?))?(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/legacy\\-app(?:/(?<nxtPpath>.+?))?(?:/)?$"
    },
    {
      "page": "/logo/[...path]",
      "regex": "^/logo/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/logo/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/src/[...path]",
      "regex": "^/src/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/src/(?<nxtPpath>.+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/config.json",
      "regex": "^/config\\.json(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/config\\.json(?:/)?$"
    },
    {
      "page": "/sizes-config.json",
      "regex": "^/sizes\\-config\\.json(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sizes\\-config\\.json(?:/)?$"
    },
    {
      "page": "/styles.css",
      "regex": "^/styles\\.css(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/styles\\.css(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}