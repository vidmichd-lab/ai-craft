AWS_ACCESS_KEY_ID=your_static_access_key_id
AWS_SECRET_ACCESS_KEY=your_static_secret_key
AWS_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net
MEDIA_BUCKET=ai-craft-media
MEDIA_PUBLIC_PREFIX=published/
MEDIA_DRAFT_PREFIX=drafts/
MEDIA_URL_TTL_SECONDS=900
MEDIA_SIGNED_GETS=true
MEDIA_PUBLIC_BASE_URL=
MEDIA_ALLOWED_ORIGINS=https://ai-craft.website.yandexcloud.net,http://localhost:8000,http://localhost:8001
MEDIA_ALLOWED_MIME_TYPES=image/webp,image/png,image/jpeg,image/svg+xml,font/woff2
MEDIA_MAX_FILE_SIZE_BYTES=10485760
