{
  "version": "1.0.0",
  "exportDate": "2024-01-01T00:00:00.000Z",
  "description": "Полная конфигурация сервиса для генерации макетов",
  "defaultTeam": "academy",
  "sizesConfig": {
    "Общие": [
      { "width": 1080, "height": 1080, "checked": true },
      { "width": 1080, "height": 1920, "checked": true },
      { "width": 1920, "height": 720, "checked": true }
    ],
    "РСЯ": [
      { "width": 1600, "height": 1200, "checked": true }
    ]
  },
  "defaultValues": {
    "defaultLogoRU": "logo/white/ru/main.svg",
    "defaultLogoKZ": "logo/white/kz/main.svg",
    "defaultLogoPRO": "logo/white/pro/main.svg",
    "logoDefaultMode": "perVariant",
    "kvSelected": "assets/pro/assets/1.webp",
    "title": "Курс «Frontend-разработчик» от Практикума",
    "subtitle": "Научитесь писать код для сайтов и веб-сервисов — с нуля за 10 месяцев",
    "legal": "Рекламодатель АНО ДПО «Образовательные технологии Яндекса»...",
    "age": "18+",
    "bgColor": "#1e1e1e",
    "titleColor": "#ffffff",
    "subtitleColor": "#e0e0e0",
    "legalColor": "#ffffff",
    "titleSize": 8,
    "subtitleSize": 4,
    "legalSize": 2,
    "ageSize": 4,
    "logoSize": 40,
    "titleWeight": "Regular",
    "subtitleWeight": "Regular",
    "legalWeight": "Regular",
    "ageWeight": "Regular"
  },
  "formatMultipliers": {
    "square": 1.0,
    "horizontal": 1.2,
    "vertical": 0.8
  },
  "adminBackgrounds": [],
  "mediaSources": {
    "remote": {
      "enabled": true,
      "label": "ai-craft-media",
      "manifestUrl": "https://example.com/api/media/manifest.json",
      "baseUrl": "",
      "strategy": "prefer"
    }
  },
  "workspaceApi": {
    "enabled": true,
    "baseUrl": "https://example.com/api"
  },
  "theme": "dark",
  "teamProfiles": {
    "academy": {
      "brandName": "Практикума",
      "defaultValues": {
        "defaultLogoRU": "logo/white/ru/main.svg",
        "defaultLogoKZ": "logo/white/kz/main.svg",
        "defaultLogoPRO": "logo/white/pro/main.svg",
        "kvSelected": "assets/pro/assets/1.webp",
        "fontFamily": "YS Text"
      }
    },
    "fintech": {
      "brandName": "Fintech Team",
      "defaultValues": {
        "defaultLogoRU": "logo/black/ru/main.svg",
        "defaultLogoKZ": "logo/black/kz/main.svg",
        "defaultLogoPRO": "logo/black/pro/main.svg",
        "kvSelected": "assets/3d/logos/40.webp",
        "fontFamily": "YS Display"
      }
    }
  }
